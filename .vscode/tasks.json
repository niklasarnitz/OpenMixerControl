{
    "tasks": [
        {
            "label": "openx32-build",
            "type": "shell",
            "command": "./compile.sh && cp ./build/omc /var/www/html/x32/ &&  ssh root@192.168.188.104 \"cd /openx32 && rm omc && wget http://192.168.188.123/x32/omc && chmod +x omc\"",
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "openx32-rpi",
            "type": "shell",
            "command": "make -j14 && dd if=../bin/x32ctrl status=progress | ssh root@192.168.188.114 \"dd of=/root/x32ctrl\"",
            "options": {},
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            }
        },
        {
            "label": "openx32-x64-SDL2",
            "type": "shell",
            "command": "export PATH=/opt/cross/bin:$PATH; make --file=Makefile_x64_SDL2 -j14",
            "options": {},
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            }
        }
    ],
    "version": "2.0.0"
}