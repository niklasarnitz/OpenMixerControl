{
    "configurations": [
        {
            "name": "(gdb) Launch",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/SDL2/omc",
            "args": ["-b"],
            //"args": ["-b", "-d", "SURFACE"],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/build/SDL2",
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                {
                    "description": "Set Disassembly Flavor to Intel",
                    "text": "-gdb-set disassembly-flavor intel",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "openx32-x64-SDL2"
        },
        {
            "type": "gdb",
            "request": "attach",
            "name": "Attach to gdbserver",
            "executable": "${workspaceFolder}/build/omc",
            "target": "192.168.188.104:10000",
            "remote": true,
            "cwd": "${workspaceRoot}/build",
            "valuesFormatting": "parseText",
            "gdbpath": "/usr/bin/gdb-multiarch", 
        }
    ],
    "version": "2.0.0"
}